{
  "name": "api-github-dev",
  "description": "Projeto de estudo React 19 que consome a API do GitHub para exibir perfis e repositórios de usuários, utilizando Vite, Styled Components e React Router.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/**/*.{js,jsx}",
    "lint:fix": "eslint --fix src/**/*.{js,jsx}",
    "format": "prettier --write src/**/*.{js,jsx}",
    "json-server": "json-server --watch db.json --id Login --routes routes.json --port 5000"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.17.0",
    "styled-components": "^6.4.2",
    "styled-normalize": "^8.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "json-server": "^0.17.4",
    "prettier": "^3.8.4",
    "vite": "^8.0.16"
  }
}
